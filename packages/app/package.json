{
  "name": "@invoker/app",
  "productName": "Invoker",
  "desktopName": "invoker.desktop",
  "version": "0.0.1",
  "description": "Invoker desktop app",
  "homepage": "https://github.com/Neko-Catpital-Labs/Invoker",
  "author": {
    "name": "Invoker Maintainers",
    "email": "dev@invoker.dev"
  },
  "private": true,
  "main": "dist/main.js",
  "build": {
    "appId": "com.invoker.app",
    "productName": "Invoker",
    "artifactName": "Invoker-${version}-${arch}.${ext}",
    "directories": {
      "output": "../../release"
    },
    "extraResources": [
      {
        "from": "../../skills",
        "to": "skills"
      }
    ],
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "asar": true,
    "npmRebuild": false,
    "publish": null,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icons/mac/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icons/png",
      "maintainer": "Invoker Maintainers <dev@invoker.dev>",
      "executableName": "invoker"
    }
  },
  "scripts": {
    "build": "tsup",
    "dist": "electron-builder --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:mac": "electron-builder --mac dmg --publish never",
    "test": "vitest run",
    "start": "unset ELECTRON_RUN_AS_NODE && electron dist/main.js",
    "dev": "tsup src/main.ts src/preload.ts --format cjs --outDir dist --external electron && unset ELECTRON_RUN_AS_NODE && electron dist/main.js",
    "test:e2e": "xvfb-run --auto-servernum playwright test"
  },
  "dependencies": {
    "@invoker/workflow-core": "workspace:*",
    "@invoker/execution-engine": "workspace:*",
    "@invoker/data-store": "workspace:*",
    "@invoker/contracts": "workspace:*",
    "@invoker/surfaces": "workspace:*",
    "@invoker/transport": "workspace:*",
    "@slack/bolt": "^4.6.0",
    "dockerode": "^4.0.0",
    "sql.js": "^1.12.0",
    "dotenv": "^16.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@invoker/test-kit": "workspace:*",
    "@playwright/test": "^1.58.2",
    "electron": "^35.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
