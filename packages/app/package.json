{
  "name": "@invoker/app",
  "productName": "Invoker",
  "desktopName": "invoker.desktop",
  "version": "0.0.7",
  "description": "Invoker desktop app",
  "homepage": "https://github.com/Neko-Catpital-Labs/Invoker",
  "author": {
    "name": "Invoker Maintainers",
    "email": "dev@invoker.dev"
  },
  "private": true,
  "main": "dist/main.js",
  "build": {
    "appId": "com.invoker.app",
    "productName": "Invoker",
    "artifactName": "Invoker-${version}-${arch}.${ext}",
    "directories": {
      "output": "../../release"
    },
    "extraResources": [
      {
        "from": "../../skills",
        "to": "skills"
      },
      {
        "from": "../../release/embedded-cli/invoker-cli",
        "to": "invoker-cli/invoker-cli"
      }
    ],
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "asar": true,
    "npmRebuild": false,
    "publish": null,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icons/mac/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icons/png",
      "maintainer": "Invoker Maintainers <dev@invoker.dev>",
      "executableName": "invoker"
    }
  },
  "scripts": {
    "build": "node scripts/verify-workspace-imports.cjs && tsup",
    "dist": "electron-builder --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:mac": "electron-builder --mac dmg --publish never",
    "test": "vitest run",
    "start": "unset ELECTRON_RUN_AS_NODE && node ../../scripts/electron.cjs dist/main.js",
    "dev": "tsup src/main.ts src/preload.ts --format cjs --outDir dist --external electron && unset ELECTRON_RUN_AS_NODE && node ../../scripts/electron.cjs dist/main.js",
    "test:e2e": "sh -c 'if [ \"${1:-}\" = \"--\" ]; then shift; fi; xvfb_server_num=${INVOKER_XVFB_SERVER_NUM:-$((200 + ($$ % 1000)))}; if command -v xvfb-run >/dev/null 2>&1; then exec xvfb-run --server-num=\"$xvfb_server_num\" --auto-servernum playwright test \"$@\"; else exec playwright test \"$@\"; fi' --",
    "test:e2e:visible": "sh -c 'export INVOKER_E2E_HIDE_WINDOW=0; if [ \"${1:-}\" = \"--\" ]; then shift; fi; xvfb_server_num=${INVOKER_XVFB_SERVER_NUM:-$((200 + ($$ % 1000)))}; if command -v xvfb-run >/dev/null 2>&1; then exec xvfb-run --server-num=\"$xvfb_server_num\" --auto-servernum playwright test \"$@\"; else exec playwright test \"$@\"; fi' --",
    "test:e2e:quiet": "pnpm run test:e2e"
  },
  "dependencies": {
    "@invoker/cli": "workspace:*",
    "@invoker/contracts": "workspace:*",
    "@invoker/data-store": "workspace:*",
    "@invoker/execution-engine": "workspace:*",
    "@invoker/runtime-adapters": "workspace:*",
    "@invoker/runtime-service": "workspace:*",
    "@invoker/surfaces": "workspace:*",
    "@invoker/transport": "workspace:*",
    "@invoker/workflow-core": "workspace:*",
    "dockerode": "^4.0.0",
    "sql.js": "^1.12.0",
    "dotenv": "^16.0.0",
    "yaml": "^2.7.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@invoker/test-kit": "workspace:*",
    "@playwright/test": "^1.58.2",
    "electron": "^35.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
