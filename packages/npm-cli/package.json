{
  "name": "@neko-catpital-labs/invoker-cli",
  "version": "0.0.3",
  "description": "Invoker standalone CLI installer",
  "type": "module",
  "bin": {
    "invoker-cli": "bin/invoker-cli.js"
  },
  "files": [
    "bin/**/*",
    "scripts/**/*",
    "vendor/.gitkeep",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/install.js",
    "test": "node bin/invoker-cli.js --version || true"
  },
  "publishConfig": {
    "access": "public"
  }
}
