#!/bin/bash
# invoker-ctl — CLI for querying and controlling a running Invoker instance.
#
# Talks to the HTTP API server on localhost:4100 (or INVOKER_API_PORT).
#
# Usage:
#   ./invoker-ctl health                           Check if Invoker is running
#   ./invoker-ctl status                           Show workflow status summary
#   ./invoker-ctl workflows                        List all workflows with IDs
#   ./invoker-ctl tasks [status]                   List tasks (optionally filter by status)
#   ./invoker-ctl queue                            Show scheduler queue status
#   ./invoker-ctl heartbeat <taskId>               Check heartbeat for a specific task
#   ./invoker-ctl audit <taskId>                   Show audit event log for a task
#   ./invoker-ctl output <taskId>                  Show captured output for a task
#   ./invoker-ctl cancel <taskId>                  Cancel a running task
#   ./invoker-ctl restart <taskId>                 Restart a failed task
#   ./invoker-ctl recreate-workflow <workflowId>    Recreate entire workflow (bump generation)
#   ./invoker-ctl resolve-conflict <taskId> [agent] Resolve merge conflict (→ awaiting_approval)
#   ./invoker-ctl approve <taskId>                 Approve a task awaiting approval
#   ./invoker-ctl reject <taskId> [reason]         Reject a task
#   ./invoker-ctl input <taskId> <text>            Provide input to a task awaiting input
#   ./invoker-ctl edit <taskId> <command>          Edit a task's command
#   ./invoker-ctl edit-type <taskId> <type>        Change a task's executor type
#   ./invoker-ctl edit-agent <taskId> <agent>      Change a task's execution agent
#   ./invoker-ctl delete-workflow <workflowId>     Delete a workflow
#   ./invoker-ctl set-merge-mode <id> <mode>       Set workflow merge mode

set -euo pipefail

PORT="${INVOKER_API_PORT:-4100}"
BASE="http://127.0.0.1:$PORT"

if ! command -v curl &>/dev/null; then
  echo "Error: curl is required but not installed." >&2
  exit 1
fi

fmt() {
  if command -v jq &>/dev/null; then
    jq "$@"
  else
    cat
  fi
}

case "${1:-}" in
  health)
    curl -sf "$BASE/api/health" | fmt '.'
    ;;

  status)
    curl -sf "$BASE/api/status" | fmt '.'
    ;;

  tasks)
    if [ -n "${2:-}" ]; then
      curl -sf "$BASE/api/tasks?status=$2" | fmt '.[] | {id, status, description, lastHeartbeatAt, secondsSinceHeartbeat}'
    else
      curl -sf "$BASE/api/tasks" | fmt '.[] | {id, status, description}'
    fi
    ;;

  workflows)
    curl -sf "$BASE/api/workflows" | fmt '.[] | {id, name, status, createdAt, updatedAt, generation}'
    ;;

  queue)
    curl -sf "$BASE/api/queue" | fmt '.'
    ;;

  recreate-workflow)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl recreate-workflow <workflowId>" >&2
      exit 1
    fi
    curl -sf -X POST "$BASE/api/workflows/$2/restart" | fmt '.'
    ;;

  delete-workflow)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl delete-workflow <workflowId>" >&2
      exit 1
    fi
    curl -sf -X DELETE "$BASE/api/workflows/$2" | fmt '.'
    ;;

  set-merge-mode)
    if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
      echo "Usage: invoker-ctl set-merge-mode <workflowId> <mode>" >&2
      echo "  mode: manual | automatic | github | external_review" >&2
      exit 1
    fi
    curl -sf -X POST -H 'Content-Type: application/json' \
      -d "{\"mode\":\"$3\"}" \
      "$BASE/api/workflows/$2/merge-mode" | fmt '.'
    ;;

  heartbeat)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl heartbeat <taskId>" >&2
      exit 1
    fi
    curl -sf "$BASE/api/tasks/$2" | fmt '{id, status, startedAt, lastHeartbeatAt, secondsSinceHeartbeat}'
    ;;

  audit)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl audit <taskId>" >&2
      exit 1
    fi
    curl -sf "$BASE/api/tasks/$2/events" | fmt '.'
    ;;

  output)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl output <taskId>" >&2
      exit 1
    fi
    curl -sf "$BASE/api/tasks/$2/output" | fmt '.output'
    ;;

  cancel)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl cancel <taskId>" >&2
      exit 1
    fi
    curl -sf -X POST "$BASE/api/tasks/$2/cancel" | fmt '.'
    ;;

  restart)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl restart <taskId>" >&2
      exit 1
    fi
    curl -sf -X POST "$BASE/api/tasks/$2/restart" | fmt '.'
    ;;

  resolve-conflict)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl resolve-conflict <taskId> [claude|codex]" >&2
      exit 1
    fi
    TASK_ID="$2"
    AGENT="${3:-claude}"
    curl -sf -X POST -H 'Content-Type: application/json' \
      -d "{\"agent\":\"$AGENT\"}" \
      "$BASE/api/tasks/$TASK_ID/resolve-conflict" | fmt '.'
    ;;

  approve)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl approve <taskId>" >&2
      exit 1
    fi
    curl -sf -X POST "$BASE/api/tasks/$2/approve" | fmt '.'
    ;;

  reject)
    if [ -z "${2:-}" ]; then
      echo "Usage: invoker-ctl reject <taskId> [reason]" >&2
      exit 1
    fi
    TASK_ID="$2"
    REASON="${3:-}"
    if [ -n "$REASON" ]; then
      curl -sf -X POST -H 'Content-Type: application/json' \
        -d "{\"reason\":\"$REASON\"}" \
        "$BASE/api/tasks/$TASK_ID/reject" | fmt '.'
    else
      curl -sf -X POST "$BASE/api/tasks/$TASK_ID/reject" | fmt '.'
    fi
    ;;

  input)
    if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
      echo "Usage: invoker-ctl input <taskId> <text>" >&2
      exit 1
    fi
    TASK_ID="$2"
    shift 2
    TEXT="$*"
    curl -sf -X POST -H 'Content-Type: application/json' \
      -d "{\"text\":\"$TEXT\"}" \
      "$BASE/api/tasks/$TASK_ID/input" | fmt '.'
    ;;

  edit)
    if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
      echo "Usage: invoker-ctl edit <taskId> <command>" >&2
      exit 1
    fi
    TASK_ID="$2"
    shift 2
    CMD="$*"
    curl -sf -X POST -H 'Content-Type: application/json' \
      -d "{\"command\":\"$CMD\"}" \
      "$BASE/api/tasks/$TASK_ID/edit" | fmt '.'
    ;;

  edit-type)
    if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
      echo "Usage: invoker-ctl edit-type <taskId> <executorType>" >&2
      exit 1
    fi
    curl -sf -X POST -H 'Content-Type: application/json' \
      -d "{\"executorType\":\"$3\"}" \
      "$BASE/api/tasks/$2/edit-type" | fmt '.'
    ;;

  edit-agent)
    if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
      echo "Usage: invoker-ctl edit-agent <taskId> <claude|codex>" >&2
      exit 1
    fi
    curl -sf -X POST -H 'Content-Type: application/json' \
      -d "{\"agent\":\"$3\"}" \
      "$BASE/api/tasks/$2/edit-agent" | fmt '.'
    ;;

  --help|-h|"")
    cat <<'EOF'
invoker-ctl — CLI for querying and controlling a running Invoker instance.

Usage:
  invoker-ctl health                           Check if Invoker is running
  invoker-ctl status                           Show workflow status summary
  invoker-ctl workflows                        List all workflows with IDs
  invoker-ctl tasks [status]                   List tasks (optionally filter by status)
  invoker-ctl queue                            Show scheduler queue status
  invoker-ctl heartbeat <taskId>               Check heartbeat for a specific task
  invoker-ctl audit <taskId>                   Show audit event log for a task
  invoker-ctl output <taskId>                  Show captured output for a task
  invoker-ctl cancel <taskId>                  Cancel a running task
  invoker-ctl restart <taskId>                 Restart a failed task
  invoker-ctl recreate-workflow <workflowId>    Recreate an entire workflow (bump generation)
  invoker-ctl resolve-conflict <taskId> [agent] Resolve merge conflict (→ awaiting_approval)
  invoker-ctl approve <taskId>                 Approve a task awaiting approval
  invoker-ctl reject <taskId> [reason]         Reject a task
  invoker-ctl input <taskId> <text>            Provide input to a task awaiting input
  invoker-ctl edit <taskId> <command>          Edit a task's command
  invoker-ctl edit-type <taskId> <type>        Change a task's executor type
  invoker-ctl edit-agent <taskId> <agent>      Change a task's execution agent (claude|codex)
  invoker-ctl delete-workflow <workflowId>     Delete a workflow
  invoker-ctl set-merge-mode <id> <mode>       Set merge mode (manual|automatic|github)

Environment:
  INVOKER_API_PORT    API port (default: 4100)

Examples:
  invoker-ctl workflows                       List all workflows
  invoker-ctl recreate-workflow abc123          Recreate workflow abc123
  invoker-ctl tasks running                   List all running tasks with heartbeat info
  invoker-ctl heartbeat add-config            Check if add-config task is alive
  invoker-ctl cancel add-config               Kill a stalled task
  invoker-ctl input my-task "yes"             Send input to a waiting task
  invoker-ctl edit my-task "npm run build"    Change task command
  invoker-ctl set-merge-mode wf-1 automatic   Set merge mode to automatic
EOF
    ;;

  *)
    echo "Unknown command: $1. Run 'invoker-ctl --help' for usage." >&2
    exit 1
    ;;
esac
