{
  "name": "invoker",
  "private": true,
  "version": "0.1.0",
  "description": "Auditable multi-agent orchestration with a mutating action graph",
  "scripts": {
    "test": "bash scripts/test-plan-to-invoker-skill.sh && pnpm -r --workspace-concurrency=1 test",
    "test:high-resource": "bash scripts/test-plan-to-invoker-skill.sh && INVOKER_VITEST_HIGH_RESOURCE=1 pnpm -r test",
    "test:low-resource": "pnpm run test",
    "test:low-resource:packages": "pnpm -r --workspace-concurrency=1 test",
    "test:guarded": "bash scripts/run-with-resource-guard.sh pnpm -r --workspace-concurrency=1 test",
    "test:plan-to-invoker-skill": "bash scripts/test-plan-to-invoker-skill.sh",
    "setup": "bash scripts/setup-cursor-skills.sh",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "setup:cursor-skills": "bash scripts/setup-cursor-skills.sh",
    "dev": "pnpm --filter @invoker/ui build && pnpm --filter @invoker/app build && pnpm --filter @invoker/app start",
    "dev:hot": "concurrently \"pnpm --filter @invoker/ui dev\" \"sleep 3 && VITE_DEV_SERVER_URL=http://localhost:5173 pnpm --filter @invoker/app build && VITE_DEV_SERVER_URL=http://localhost:5173 pnpm --filter @invoker/app start\""
  },
  "engines": {
    "node": ">=22 <23"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.invoker.app",
    "productName": "Invoker",
    "directories": {
      "output": "release"
    },
    "files": [
      "packages/app/dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "devDependencies": {
    "aws4": "^1.13.2"
  }
}
